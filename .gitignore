*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/

# IDE / OS
.DS_Store
.idea/
.vscode/
*.swp
Thumbs.db

# Secrets
.env
*.env
